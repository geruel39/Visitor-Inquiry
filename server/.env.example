# MySQL (Clever Cloud)
MYSQL_ADDON_HOST=your-mysql-host
MYSQL_ADDON_DB=your-db-name
MYSQL_ADDON_USER=your-db-user
MYSQL_ADDON_PORT=3306
MYSQL_ADDON_PASSWORD=your-db-password
MYSQL_ADDON_URI=mysql://user:pass@host:3306/dbname

# Server
PORT=5000

# Email (Gmail example)
EMAIL_USER=you@example.com
EMAIL_PASS=your-email-password
